{
  "version": 2,
  "crons": [{ "path": "/api/cron/renew-gmail-watch", "schedule": "0 0 */6 * *" }],
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "pages/**",
          "js/**",
          "media/**",
          "data/.gitkeep"
        ],
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
