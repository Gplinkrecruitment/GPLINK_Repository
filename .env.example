# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Auth/security
AUTH_DISABLED=false
AUTH_SECRET=replace-with-strong-random-secret
COOKIE_SECURE=true
ADMIN_EMAILS=admin@mygplink.com.au,ops@mygplink.com.au
ADMIN_ALLOWED_HOSTS=admin.mygplink.com.au
ADMIN_COOKIE_NAME=gp_admin_session
ADMIN_SESSION_TTL_MS=28800000

# Auth throttles (optional overrides)
OTP_TTL_MS=300000
OTP_MAX_ATTEMPTS=5
RATE_WINDOW_MS=600000
RATE_MAX_SEND=5
AUTH_RATE_WINDOW_MS=600000
AUTH_RATE_MAX_ATTEMPTS=12
SESSION_TTL_MS=43200000
MAX_JSON_BODY_BYTES=8388608
ENFORCE_SAME_ORIGIN=true
REQUIRE_SUPABASE_DB=true

# Persistent datastore path
# For Vercel, prefer /tmp/app-db.json (ephemeral) or move state to a managed DB.
DB_FILE_PATH=./data/app-db.json

# Supabase (cloud)
SUPABASE_URL=https://rqrqcfxalkvzwbedvsjs.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-side only. Required for /api/state Supabase persistence.
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx
