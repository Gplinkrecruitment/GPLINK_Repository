# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Auth/security — AUTH_SECRET MUST be a strong random string (32+ chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_DISABLED=false
AUTH_SECRET=replace-with-strong-random-secret
COOKIE_SECURE=true
ADMIN_EMAILS=admin@mygplink.com.au,ops@mygplink.com.au
ADMIN_ALLOWED_HOSTS=admin.mygplink.com.au
ADMIN_COOKIE_NAME=gp_admin_session
ADMIN_SESSION_TTL_MS=28800000

# Auth throttles (optional overrides)
OTP_TTL_MS=300000
OTP_MAX_ATTEMPTS=5
RATE_WINDOW_MS=600000
RATE_MAX_SEND=5
AUTH_RATE_WINDOW_MS=600000
AUTH_RATE_MAX_ATTEMPTS=12
SESSION_TTL_MS=43200000
MAX_JSON_BODY_BYTES=8388608
ENFORCE_SAME_ORIGIN=true
REQUIRE_SUPABASE_DB=true

# OAuth 2.0 token TTLs (defaults: 15 min access, 7 day refresh)
# OAUTH_ACCESS_TTL_MS=900000
# OAUTH_REFRESH_TTL_MS=604800000

# Persistent datastore path
# For Vercel, prefer /tmp/app-db.json (ephemeral) or move state to a managed DB.
DB_FILE_PATH=./data/app-db.json

# Supabase (cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-side only. Required for /api/state Supabase persistence.
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx
SUPABASE_DOCUMENT_BUCKET=gp-link-documents
SUPABASE_SCAN_NORMALIZER_FUNCTION=normalize-scan-image

# Zoho Recruit integration (server-side only)
ZOHO_RECRUIT_CLIENT_ID=
ZOHO_RECRUIT_CLIENT_SECRET=
ZOHO_RECRUIT_ACCOUNTS_SERVER=https://accounts.zoho.com
# Use your live app callback in production, for example:
# https://app.mygplink.com.au/api/integrations/zoho-recruit/callback
ZOHO_RECRUIT_REDIRECT_URI=https://app.mygplink.com.au/api/integrations/zoho-recruit/callback
# Default scope for live job openings. Expand only if needed.
ZOHO_RECRUIT_SCOPES=ZohoRECRUIT.modules.jobopening.READ
ZOHO_RECRUIT_SYNC_PAGE_SIZE=200
ZOHO_RECRUIT_SYNC_MAX_PAGES=25
# Optional: protect /api/integrations/zoho-recruit/cron-sync for external/Vercel cron callers.
ZOHO_RECRUIT_SYNC_CRON_SECRET=

# Optional media CDN/Blob URLs for the dashboard hero video
HERO_DESKTOP_MP4_URL=
HERO_DESKTOP_WEBM_URL=
HERO_MOBILE_MP4_URL=
HERO_MOBILE_WEBM_URL=
