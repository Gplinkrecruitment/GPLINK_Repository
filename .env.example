# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Auth/security — AUTH_SECRET MUST be a strong random string (32+ chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_DISABLED=false
AUTH_SECRET=replace-with-strong-random-secret
COOKIE_SECURE=true
ADMIN_EMAILS=admin@mygplink.com.au,ops@mygplink.com.au
ADMIN_ALLOWED_HOSTS=admin.mygplink.com.au
ADMIN_COOKIE_NAME=gp_admin_session
ADMIN_SESSION_TTL_MS=28800000

# Auth throttles (optional overrides)
OTP_TTL_MS=300000
OTP_MAX_ATTEMPTS=5
RATE_WINDOW_MS=600000
RATE_MAX_SEND=5
AUTH_RATE_WINDOW_MS=600000
AUTH_RATE_MAX_ATTEMPTS=12
SESSION_TTL_MS=43200000
MAX_JSON_BODY_BYTES=8388608
ENFORCE_SAME_ORIGIN=true
REQUIRE_SUPABASE_DB=true

# OAuth 2.0 token TTLs (defaults: 15 min access, 7 day refresh)
# OAUTH_ACCESS_TTL_MS=900000
# OAUTH_REFRESH_TTL_MS=604800000

# Persistent datastore path
# For Vercel, prefer /tmp/app-db.json (ephemeral) or move state to a managed DB.
DB_FILE_PATH=./data/app-db.json

# Supabase (cloud)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Server-side only. Required for /api/state Supabase persistence.
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_xxx
SUPABASE_DOCUMENT_BUCKET=gp-link-documents
SUPABASE_SCAN_NORMALIZER_FUNCTION=normalize-scan-image

# Zoho Recruit integration (server-side only)
ZOHO_RECRUIT_CLIENT_ID=
ZOHO_RECRUIT_CLIENT_SECRET=
ZOHO_RECRUIT_ACCOUNTS_SERVER=https://accounts.zoho.com
# Use your live app callback in production, for example:
# https://app.mygplink.com.au/api/integrations/zoho-recruit/callback
ZOHO_RECRUIT_REDIRECT_URI=https://app.mygplink.com.au/api/integrations/zoho-recruit/callback
# Default scope for live job openings. Expand only if needed.
ZOHO_RECRUIT_SCOPES=ZohoRECRUIT.modules.jobopening.READ
ZOHO_RECRUIT_SYNC_PAGE_SIZE=200
ZOHO_RECRUIT_SYNC_MAX_PAGES=25
# Optional: protect /api/integrations/zoho-recruit/cron-sync for external schedulers.
# If you use the included GitHub Actions workflow, set the same value as a repo secret.
ZOHO_RECRUIT_SYNC_CRON_SECRET=

# Google Maps (required for career/lifestyle features)
GOOGLE_MAPS_BROWSER_API_KEY=
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_MAPS_MAP_ID=

# Google Places API (server-side, for /api/schools/search)
GOOGLE_PLACES_API_KEY=

# Anthropic AI (for qualification verification)
ANTHROPIC_API_KEY=
ANTHROPIC_DAILY_LIMIT_USD=100

# OpenAI (for document classification)
OPENAI_API_KEY=

# Hybrid multi-model agents (optional)
# Uses local subscription-backed CLIs (`codex` + `claude`) rather than direct API calls.
# Optional if the binaries are already on PATH:
# CODEX_CLI_PATH=/absolute/path/to/codex
# CLAUDE_CLI_PATH=/absolute/path/to/claude
# SUPER_ADMIN_ALLOWED_HOSTS=ceo.mygplink.com.au
AGENT_PROFILE=balanced
AGENT_COLLABORATION_MODE=paired
AGENT_COMPLEXITY_MODE=auto
AGENT_ENABLE_CLAUDE_BROWSER_USE_MCP=true
CLAUDE_BROWSER_MCP_NAME=browser-use
AGENT_BRIDGE_HOST=127.0.0.1
AGENT_BRIDGE_PORT=4317
# AGENT_BRIDGE_ALLOWED_ORIGINS=https://ceo.admin.mygplink.com.au,https://admin.mygplink.com.au
# Optional if you want the local bridge to poll a live dashboard instead of waiting
# for the browser to fetch localhost directly:
# AGENT_BRIDGE_RELAY_URL=https://ceo.admin.mygplink.com.au
# AGENT_BRIDGE_RELAY_TOKEN=
# AGENT_BRIDGE_RELAY_SYNC_MS=4000
# HYBRID_AGENT_BRIDGE_TOKEN_TTL_MS=43200000
# HYBRID_AGENT_BRIDGE_STALE_MS=45000
OPENAI_COMPLEX_MODEL=gpt-5.4
OPENAI_STANDARD_MODEL=gpt-5.4-mini
OPENAI_SIMPLE_MODEL=gpt-5.4-mini
OPENAI_COMPLEX_REVIEW_MODEL=gpt-5.4
OPENAI_STANDARD_REVIEW_MODEL=gpt-5.4-mini
# Pin this to your exact Claude Opus 4.6 model name if your local CLI exposes one.
ANTHROPIC_COMPLEX_MODEL=opus
ANTHROPIC_STANDARD_MODEL=sonnet
ANTHROPIC_SIMPLE_MODEL=sonnet
AGENT_MAX_FILE_CONTEXT_CHARS=24000
AGENT_MAX_PLANNER_FILES=220
AGENT_MAX_SUBTASKS=6

# Domain.com.au API (for lifestyle housing search)
DOMAIN_API_KEY=
DOMAIN_API_ACCESS_TOKEN=
DOMAIN_API_CLIENT_ID=
DOMAIN_API_CLIENT_SECRET=

# AI rate limit bypass (comma-separated emails, use sparingly)
# AI_VERIFY_UNLIMITED_EMAILS=

# Optional media CDN/Blob URLs for the dashboard hero video
HERO_DESKTOP_MP4_URL=
HERO_DESKTOP_WEBM_URL=
HERO_MOBILE_MP4_URL=
HERO_MOBILE_WEBM_URL=
